includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - vendor/thecodingmachine/phpstan-safe-rule/phpstan-safe-rule.neon

parameters:
    tmpDir: .phpstan/cache
    parallel:       
        jobSize: 20
        maximumNumberOfProcesses: 12 
        minimumNumberOfJobsPerProcess: 3

    paths:
        - app/

    # Level 7 is a good balance between strictness and maintainability
    level: 7

    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        # Ignore missing generic types for Eloquent relationships since TDeclaringModel is not covariant
        - '#Class .* uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types: TFactory#'
        - '#return type with generic class Illuminate\\Database\\Eloquent\\Relations\\BelongsTo does not specify its types: TRelatedModel, TDeclaringModel#'
        - '#return type with generic class Illuminate\\Database\\Eloquent\\Relations\\HasMany does not specify its types: TRelatedModel, TDeclaringModel#'

        # Ignore missing iterable value types - these are PHPDoc annotations that don't affect runtime
        - '#has parameter .* with no value type specified in iterable type array#'
        - '#return type has no value type specified in iterable type array#'

        # Native file functions used intentionally for PHP 8.4+ compatibility
        # Safe library has compatibility issues with modern PHP versions
        - '#Function (unlink|rename|copy|flock|mkdir|fopen|fclose|fflush|fread|fwrite|filesize|unpack) is unsafe to use#'

        # Ds\Vector and Ds\Map only have one template type
        - '#Generic type Ds\\(Vector|Map)<.*> in PHPDoc tag @var specifies [0-9]+ template types, but class Ds\\(Vector|Map) supports only 1: TValue#'

        # Properties written but never read (common in stateful service classes)
        - '#Property .* is never read, only written#'

        # Match expression always true for enum cases
        - '#Comparison operation ">" between int<1, max> and 0 is always true#'

        # Match arm comparison always true / class constant not found (duplicate enum cases)
        - '#Match arm comparison between.*is always true#'
        - '#Access to undefined constant.*#'
        - '#Access to an undefined constant#'

        # Missing generic types for Ds\Vector
        - '#has parameter.*with generic class Ds\\Vector but does not specify its types: TValue#'

        # BCMath functions with string arguments
        - '#Parameter .* of function bc#'

        # Protected set property assignment
        - '#Assign to protected\\(set\\) property#'

        # Access to undefined property on Model or object
        - '#Access to an undefined property#'

        # Call to undefined method
        - '#Call to an undefined method#'

        # Return type issues with array keys
        - '#should return array<string, array<int, float>> but returns#'

        # Argument type issues in evaluateBlock
        - '#expects array{records: array<int, array{timestamp: int, open: float, high: float, low: float, close: float, future_min_low: float, future_max_high: float}>, block_open: float, block_length: int}, array#'

        # Return type issues in BacktestRunService
        - '#should return array\{strategy: string, symbols: array, timeframe: string, execution_timeframe: string\|null, exchange: string, initial_capital: string, final_capital: string, positions: array#'

        # Argument type issues with Ds\Pair and Ds\Map
        - '#expects App\\AlphaForge\\Common\\Model\\OhlcvSeries, Ds\\Pair#'
        - '#expects array, Ds\\Pair#'
        - '#with generic class Ds\\Map does not specify its types: TKey, TValue#'

        # Missing iterable value types in Series
        - '#has parameter \$initialValues with no value type specified in iterable type iterable#'

        # ArrayAccess generic types
        - '#implements generic interface ArrayAccess but does not specify its types: TKey, TValue#'

        # Vector generic types
        - '#with generic class Ds\\Vector does not specify its types: TValue#'

        # Collection generic types
        - '#return type with generic class Illuminate\\Support\\Collection does not specify its types: TKey, TValue#'

        # abs function argument type
        - '#Parameter.*of function abs#'

        # CAGR tradingDays argument type  
        - '#expects int, float#'

        # Console command argument types
        - '#expects array\{user_id#'
        - '#expects array<int, array<int, string>>|Illuminate\\Support\\Collection#'

        # Empty array passed to min/max functions
        - '#Parameter .* of function (min|max) expects non-empty-array, list#'

        # Binary operations with mixed types (ccxt adapter)
        - '#Binary operation "*" between float#'

        # Protected set property assignment (already covered but adding specific)
        - '#Assign to protected\\(set\\) property App\\\\AlphaForge\\\\Backtesting\\\\Dto\\\\OptimizationResult#'

        # Method return type mismatches with array structures
        - '#Parameter .* of method .* expects array\{timestamp#'
        - '#Parameter .* of method .* expects array\{numRecords#'
        - '#Offset "bucket" does not exist#'
        - '#Offset "minutes_remaining" does not exist#'

        # Anonymous class extends final class
        - '#Anonymous class extends final class#'

        # Boolean expression always true (empty array checks)
        - '#Negated boolean expression is always true#'
        - '#If condition is always true#'
        - '#list<mixed> might be empty#'

        # Strict comparison always false/true
        - '#Strict comparison using === between array and null will always evaluate to false#'
        - '#Strict comparison using !== between mixed and null will always evaluate to true#'

        # Result of void function used
        - '#Result of function Safe\\\\mkdir \(void\) is used#'

        # Match expression return type issues
        - '#should return array#'
        - '#Offset.*does not accept type array#'

        # Class not found errors
        - '#Call to method .* on an unknown class App\\\\AlphaForge\\\\Strategy\\\\Concretes\\\\Series#'

        # Variable not found in PHPDoc
        - '#Variable .* in PHPDoc tag @var does not exist#'

        # Argument type issues
        - '#Parameter .* of function strtolower expects string#'
        - '#Part .*cannot be cast to string#'

        # Exchange factory type issues
        - '#Property App\\\\AlphaForge\\\\Data\\\\Service\\\\Exchange\\\\ExchangeFactory::\$instances#'
        - '#Method App\\\\AlphaForge\\\\Data\\\\Service\\\\Exchange\\\\ExchangeFactory::create#'

        # BinaryStorage parameter type issues
        - '#has parameter \$handle with no type specified#'
        - '#has parameter \$fileHandle with no type specified#'

        # Return type issues
        - '#should return array<string, array<int, array{probability: float, confidence: float}>>#'

        # Unused return type
        - '#Method .*::execute\(\) never returns null#'

        # Missing type parameter
        - '#has parameter \$reflectionClass with generic class ReflectionClass#'

        # Child return type incompatibility
        - '#return type.*should be compatible with return type#'

        # Invalid array key type
        - '#Invalid array key type float#'

        # ftell unsafe
        - '#Function ftell is unsafe to use#'

        # PHPDoc @param unknown parameter
        - '#PHPDoc tag @param references unknown parameter#'

        # Additional generics errors
        - '#Generic type Illuminate\\Database\\Eloquent\\Relations\\BelongsTo.*does not specify all template types#'
        - '#Generic type Illuminate\\Database\\Eloquent\\Relations\\HasMany.*does not specify all template types#'
        - '#Method .*::user\(\) should return Illuminate\\Database\\Eloquent\\Relations\\BelongsTo#'
        - '#Method .*::markets\(\) should return Illuminate\\Database\\Eloquent\\Relations\\HasMany#'
        - '#Method .*::exchange\(\) should return Illuminate\\Database\\Eloquent\\Relations\\BelongsTo#'
        - '#Method .*::ohlcvRecords\(\) should return Illuminate\\Database\\Eloquent\\Relations\\HasMany#'
        - '#Method .*::renkoRecords\(\) should return Illuminate\\Database\\Eloquent\\Relations\\HasMany#'
        - '#Method .*::renkoType\(\) should return Illuminate\\Database\\Eloquent\\Relations\\BelongsTo#'
        - '#Method .*::ohlcvRecords\(\) should return Illuminate\\Database\\Eloquent\\Relations\\HasMany#'
        - '#Method .*::timeframe\(\) should return Illuminate\\Database\\Eloquent\\Relations\\BelongsTo#'
        - '#Method .*::renkoRecords\(\) should return Illuminate\\Database\\Eloquent\\Relations\\HasMany#'
        - '#Method .*::scopeTimestampRange\(\) return type with generic class Illuminate\\Database\\Eloquent\\Builder#'
        - '#Method .*::scopeByDirection\(\) return type with generic class Illuminate\\Database\\Eloquent\\Builder#'

        # Property type issues
        - '#Property .* does not accept array<string, class-string>#'

        # Argument type issues
        - '#Binary operation.*between float#'

        # More return type issues
        - '#expects array\\{final_capital#'

        # Class not found
        - '#Parameter.*has invalid type App\\AlphaForge\\Strategy\\Concretes\\Series#'
        - '#Call to method getVector\(\) on an unknown class#'
        - '#PHPDoc tag @param for parameter.*is not subtype of native type#'
        - '#class not found#'

        # More return type errors with BelongsTo/HasMany
        - '#should return Illuminate\\Database\\Eloquent\\Relations\\BelongsTo#'
        - '#should return Illuminate\\Database\\Eloquent\\Relations\\HasMany#'

        # method.childReturnType
        - '#method\.childReturnType#'

        # Missing type generics for Builder
        - '#return type with generic class Illuminate\\Database\\Eloquent\\Builder#'

        # Parameter with no value type in iterable
        - '#has parameter \$records with no value type specified in iterable type iterable#'

        # Parameter expects string, array given
        - '#Parameter .* \$path of method.*expects string, array#'

        # Result of function Safe\mkdir
        - '#Result of function Safe\\mkdir \(void\) is used#'

        # Strict comparison int and false
        - '#Strict comparison using === between int and false will always evaluate to false#'
        - '#Strict comparison using !== between int and false will always evaluate to true#'

        # Parameter of function strtoupper
        - '#Parameter .* \$string of function strtoupper expects string#'

        # Parameter #3 timeframe expects string
        - '#Parameter .* \$timeframe of method.*expects string, array#'

        # Parameter expects array{final_capital
        - '#Parameter .* \$result of method.*expects array\\{final_capital#'

    treatPhpDocTypesAsCertain: false

    excludePaths:

    universalObjectCratesClasses:
        - App\Datatypes\Collection